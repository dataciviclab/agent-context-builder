# agent-context-builder — Environment Variables

# GitHub Token — obbligatorio per refresh_context e fetch discussioni
# GITHUB_TOKEN=ghp_abc123...

# Override repo/branch artifact (default: dataciviclab/agent-context-builder / context)
# ACB_REPO=dataciviclab/agent-context-builder
# ACB_BRANCH=context

# Logging
# ACB_LOG_LEVEL=INFO
